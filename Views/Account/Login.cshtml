@model AspNetCore.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="auth-shell">
    <section class="auth-identity">
        <div class="auth-emblem">SysAC</div>
        <p class="auth-kicker">Portal academico</p>
        <h1>Gestao escolar com clareza institucional.</h1>
        <p class="auth-copy">Ambiente para acompanhar alunos, professores, disciplinas e notas em uma rotina academica organizada.</p>
    </section>

    <section class="auth-panel">
        <div class="auth-panel-header">
            <p class="auth-kicker">Acesso restrito</p>
            <h2>Entrar</h2>
        </div>

        <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" placeholder="exemplo@escola.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Senha" class="form-label">Senha</label>
                    <input asp-for="Senha" type="password" class="form-control" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Entrar</button>
        </form>

        <div class="auth-link">
            <a asp-controller="Account" asp-action="Cadastrar">Criar usuario</a>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
