@model IEnumerable<Disciplina>

@{
    ViewData["Title"] = "Disciplinas";
}

<div class="page-heading">
    <div>
        <p class="section-kicker">Matriz curricular</p>
        <h1>Disciplinas</h1>
    </div>
    <a asp-action="Create" class="btn btn-success">Nova disciplina</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nome</th>
            <th>Periodo</th>
            <th>Carga horaria</th>
            <th>Professor</th>
            <th class="text-center">Acoes</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var disciplina in Model)
            {
                <tr>
                    <td>@disciplina.Nome</td>
                    <td>@disciplina.Periodo</td>
                    <td>@disciplina.CargaHoraria</td>
                    <td>@(disciplina.Professor?.Nome ?? "-")</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@disciplina.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@disciplina.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">Nenhuma disciplina encontrada.</td>
            </tr>
        }
    </tbody>
</table>
