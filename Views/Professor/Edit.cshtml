@model Professor

@{
    ViewData["Title"] = "Editar professor";
}

<h1>Editar professor</h1>

<form asp-action="Edit" method="post" class="row g-3">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Sobrenome" class="form-label"></label>
        <input asp-for="Sobrenome" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Cpf" class="form-label"></label>
        <input asp-for="Cpf" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
    </div>
    <div class="col-md-4">
        <label asp-for="DataNascimento" class="form-label">Data de nascimento</label>
        <input asp-for="DataNascimento" type="date" class="form-control" />
    </div>
    <div class="col-md-6">
        <label asp-for="Siap" class="form-label"></label>
        <input asp-for="Siap" class="form-control" />
        <span asp-validation-for="Siap" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Area" class="form-label"></label>
        <input asp-for="Area" class="form-control" />
        <span asp-validation-for="Area" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-success">Salvar</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>
