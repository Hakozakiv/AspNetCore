@model IEnumerable<AspNetCore.Models.Professor>

@{
    ViewData["Title"] = "Lista de Professores";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Professores Cadastrados</h1>
        <a asp-action="Create" class="btn btn-success">Novo Professor</a>
    </div>

    <table class="table table-striped table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Registro Funcional</th>
                <th>Área de Atuação
                </th>
                <th class="text-center">Ações</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var professor in Model)
                {
                    <tr>
                        <td>@professor.Nome</td>
                        <td>@professor.Email</td>
                        <td>@professor.Siap</td>
                        <td>@professor.Area</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@professor.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@professor.Id" class="btn btn-sm btn-danger">Excluir</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="text-center text-muted">Nenhum professor encontrado.</td>
                </tr>
            }
        </tbody>
    </table>
</div>