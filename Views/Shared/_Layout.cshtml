@using Microsoft.AspNetCore.Http
@{
    var usuarioLogado = Context.Session.GetString("Usuario");
    var estaLogado = !string.IsNullOrEmpty(usuarioLogado);
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SysAC</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Aluno" asp-action="Index">SysAC</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Alternar navegacao">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (estaLogado)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Aluno" asp-action="Index">Alunos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Professor" asp-action="Index">Professores</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Disciplina" asp-action="Index">Disciplinas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Nota" asp-action="Index">Notas</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (estaLogado)
                        {
                            <li class="nav-item d-flex align-items-center me-2 text-muted">
                                @usuarioLogado
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark">Sair</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Account" asp-action="Cadastrar">Cadastrar</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @if (TempData["Mensagem"] != null)
            {
                <div class="alert alert-@TempData["Tipo"]">
                    @TempData["Mensagem"]
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted py-3">
        <div class="container">
            &copy; 2026 - SysAC
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
