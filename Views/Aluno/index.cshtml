@model IEnumerable<Aluno>

@{
    ViewData["Title"] = "Alunos";
}

<div class="page-heading">
    <div>
        <p class="section-kicker">Secretaria academica</p>
        <h1>Alunos</h1>
    </div>
    <a asp-action="Create" class="btn btn-success">Novo aluno</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Foto</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Matricula</th>
            <th>Curso</th>
            <th class="text-center">Acoes</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var aluno in Model)
            {
                <tr>
                    <td><div class="d-flex right-align mb-3">
                        <img src="~/img/Anonimo.jpeg" alt="Alunos" class="mb-3" style="max-width: 60px;" />
                     </div></td>
                    <td>@aluno.Nome @aluno.Sobrenome</td>
                    <td>@aluno.Email</td>
                    <td>@aluno.Matricula</td>
                    <td>@aluno.Curso</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@aluno.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@aluno.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center text-muted">Nenhum aluno encontrado.</td>
            </tr>
        }
    </tbody>
</table>
