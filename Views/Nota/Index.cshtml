@model IEnumerable<Nota>

@{
    ViewData["Title"] = "Notas";
}

<div class="page-heading">
    <div>
        <p class="section-kicker">Avaliacao academica</p>
        <h1>Notas</h1>
    </div>
    <a asp-action="Create" class="btn btn-success">Nova nota</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Aluno</th>
            <th>Disciplina</th>
            <th>Descricao</th>
            <th>Nota</th>
            <th class="text-center">Acoes</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Any())
        {
            foreach (var nota in Model)
            {
                <tr>
                    <td>@nota.Aluno?.Nome</td>
                    <td>@nota.Disciplina?.Nome</td>
                    <td>@nota.Descricao</td>
                    <td>@nota.Valor</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@nota.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Delete" asp-route-id="@nota.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">Nenhuma nota encontrada.</td>
            </tr>
        }
    </tbody>
</table>
